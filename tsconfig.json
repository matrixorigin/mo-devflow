{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@mo-devflow/shared": ["packages/shared/src/index.ts"],
      "@mo-devflow/config": ["packages/config/src/index.ts"],
      "@mo-devflow/db": ["packages/db/src/index.ts"],
      "@mo-devflow/github": ["packages/github/src/index.ts"],
      "@mo-devflow/rules": ["packages/rules/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "packages/**/*.tsx", "vite.config.ts"]
}
