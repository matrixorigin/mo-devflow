# MatrixOne connection. The app uses a dedicated database and never writes into
# other application databases.
MO_DEVFLOW_DB_HOST=127.0.0.1
MO_DEVFLOW_DB_PORT=6001
MO_DEVFLOW_DB_USER=root
MO_DEVFLOW_DB_PASSWORD=
MO_DEVFLOW_DB_NAME=mo_devflow

# GitHub. Public repositories can sync without a token, but authenticated reads
# have higher rate limits and can access private data according to token scope.
# Do not commit real tokens.
#MO_DEVFLOW_GITHUB_TOKEN=

# Runtime
# The committed base profile can be extended by an untracked sibling file such
# as config/repos/matrixone.local.yaml for real users, testers, and local paths.
MO_DEVFLOW_PROFILE=config/repos/matrixone.yaml
MO_DEVFLOW_API_HOST=0.0.0.0
MO_DEVFLOW_API_PORT=18081
MO_DEVFLOW_WEB_PORT=5173
# API read-model cache for /api/dashboard. Set to 0 to disable.
MO_DEVFLOW_DASHBOARD_CACHE_SECONDS=15
# Public dashboard base URL used in notification deep links.
#MO_DEVFLOW_DASHBOARD_URL=http://localhost:5173
# Comma-separated browser origins allowed to call the API with credentials.
# Defaults to http://localhost:${MO_DEVFLOW_WEB_PORT} and http://127.0.0.1:${MO_DEVFLOW_WEB_PORT}.
# Values must be origins only: scheme + host + optional port, no path/query/fragment.
#MO_DEVFLOW_ALLOWED_ORIGINS=http://localhost:5173
MO_DEVFLOW_SESSION_TTL_DAYS=14
MO_DEVFLOW_ACTION_PREVIEW_TTL_MINUTES=10
# Per-client fixed-window guard for personal GitHub token binding attempts.
MO_DEVFLOW_TOKEN_BIND_RATE_LIMIT_MAX=5
MO_DEVFLOW_TOKEN_BIND_RATE_LIMIT_WINDOW_SECONDS=300
# Required before users can bind personal GitHub tokens.
# Generate with: openssl rand -base64 32
#MO_DEVFLOW_TOKEN_ENCRYPTION_KEY=
#MO_DEVFLOW_TOKEN_ENCRYPTION_KEY_VERSION=v1
#MO_DEVFLOW_COOKIE_SECURE=false
MO_DEVFLOW_SYNC_MAX_PAGES=2
# Anonymous GitHub has a 60 requests/hour limit. Keep detail enrichment off
# unless a service read token is configured or you intentionally run a small
# one-shot enrichment.
MO_DEVFLOW_PR_DETAIL_MAX_ITEMS=0
# Low-priority PR detail backfill runs as a separate worker layer. Anonymous
# default is 0; service-token default is 25. Set explicitly for one-shot local
# repair if you understand the GitHub rate-limit cost.
#MO_DEVFLOW_PR_BACKFILL_MAX_ITEMS=25
#MO_DEVFLOW_PR_BACKFILL_INTERVAL_SECONDS=1800
# Low-priority issue/PR comment backfill powers deferred-explanation checks and
# configured comment-based testing handoff signals.
#MO_DEVFLOW_COMMENT_BACKFILL_MAX_ITEMS=25
#MO_DEVFLOW_COMMENT_BACKFILL_INTERVAL_SECONDS=1800
MO_DEVFLOW_SYNC_INTERVAL_SECONDS=300
MO_DEVFLOW_CACHE_STALE_HOURS=6
# Required before the GitHub webhook endpoint will ingest deliveries. The same
# value must be configured as the webhook secret in GitHub.
#MO_DEVFLOW_GITHUB_WEBHOOK_SECRET=
MO_DEVFLOW_WEBHOOK_PROCESS_INTERVAL_SECONDS=60
MO_DEVFLOW_WEBHOOK_PROCESS_LIMIT=20
MO_DEVFLOW_WEBHOOK_PROCESS_LEASE_SECONDS=300
MO_DEVFLOW_WORKER_TICK_SECONDS=30
MO_DEVFLOW_WORKER_HEARTBEAT_STALE_SECONDS=120
MO_DEVFLOW_WORKER_MAX_JOBS_PER_TICK=3
MO_DEVFLOW_JOB_LEASE_SECONDS=600
# `/health` and the dashboard warn when the oldest due job waits this long.
MO_DEVFLOW_JOB_QUEUE_PENDING_WARN_HOURS=0.25
MO_DEVFLOW_JOB_RETRY_BASE_SECONDS=60
MO_DEVFLOW_JOB_RETRY_MAX_SECONDS=1800
MO_DEVFLOW_GITHUB_RATE_LIMIT_RETRY_SECONDS=3600
MO_DEVFLOW_GITHUB_BLOCKED_RECHECK_SECONDS=3600
MO_DEVFLOW_RULES_INTERVAL_SECONDS=300
MO_DEVFLOW_METRICS_INTERVAL_SECONDS=1800
# Keep enough daily cached metrics for weekly and monthly digest windows.
MO_DEVFLOW_METRICS_RETENTION_DAYS=120
MO_DEVFLOW_AI_DRIFT_INTERVAL_SECONDS=1800
MO_DEVFLOW_NOTIFICATION_INTERVAL_SECONDS=300

# Future enterprise WeChat channel.
#MO_DEVFLOW_WECOM_WEBHOOK_URL=
